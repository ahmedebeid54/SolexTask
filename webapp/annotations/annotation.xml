<Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="local">
    <Annotations Target="NorthwindModel.Product">
        <Annotation Term="UI.LineItem">
            <Collection>
                <Record Type="UI.DataField">
                    <Property Name="Value" Path="ProductID" />
                </Record>
                <Record Type="UI.DataField">
                    <Property Name="Value" Path="ProductName" />
                </Record>
                <Record Type="UI.DataField">
                    <Property Name="Value" Path="UnitPrice" />
                </Record>
                <Record Type="UI.DataField">
                    <Property Name="Value" Path="UnitsInStock" />
                </Record>
            </Collection>
        </Annotation>

        <Annotation Term="UI.HeaderInfo">
            <Record>
                <Property Name="TypeName" String="Product Detail" />
                <Property Name="TypeNamePlural" String="Product Details" />
                <Property Name="Title">
                    <Record Type="UI.DataField">
                        <Property Name="Value" Path="ProductName" />
                    </Record>
                </Property>
            </Record>
        </Annotation>

        <Annotation Term="UI.Facets">
            <Collection>
                <Record Type="UI.ReferenceFacet">
                    <Property Name="Label" String="General Information" />
                    <Property Name="Target" AnnotationPath="@UI.FieldGroup#GeneralInfo" />
                </Record>
            </Collection>
        </Annotation>

        <Annotation Term="UI.FieldGroup" Qualifier="GeneralInfo">
            <Record>
                <Property Name="Data">
                    <Collection>
                        <Record Type="UI.DataField">
                            <Property Name="Value" Path="ProductID" />
                        </Record>
                        <Record Type="UI.DataField">
                            <Property Name="Value" Path="QuantityPerUnit" />
                        </Record>
                        <Record Type="UI.DataField">
                            <Property Name="Value" Path="ReorderLevel" />
                        </Record>
                    </Collection>
                </Property>
            </Record>
        </Annotation>
    </Annotations>
</Schema>